  const retry = spawnSync(
    process.execPath,
    ["--experimental-sqlite", __filename, ...process.argv.slice(2)],
    {
      stdio: "inherit",
      env: { ...process.env, CM_SQLITE_REEXEC: "1" },
    }
  );
  process.exit(retry.status ?? 1);
}

